{
    "manifest_version": 3,
    "name": "Vanish",
    "version": "1.0",
    "description": "Premium element eraser & data extractor. Press Cmd+Shift+X.",
    "permissions": ["storage"],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_start"
      }
    ]
  }